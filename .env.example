# PostgreSQL 接続文字列(Neon 等)
DATABASE_URL=postgres://user:password@host/dbname

# AI実行モード: claude-code(既定・Proサブスク枠)/ api(成長時・Anthropic API)
AI_PROVIDER=claude-code

# --- モードA: Claude Code ヘッドレス(CI実行時のみ必要。ローカルはOAuthログイン済みなら不要) ---
# `claude setup-token` で発行
# CLAUDE_CODE_OAUTH_TOKEN=

# --- モードB: Anthropic API(AI_PROVIDER=api 時のみ必要) ---
# ANTHROPIC_API_KEY=
# DIGEST_MODEL=claude-sonnet-5
# CURATE_MODEL=claude-sonnet-5
